{
  "$schema": "https://raw.githubusercontent.com/maxange-developer/rag-eval-cli/main/schema.json",
  "endpoint": {
    "url": "http://localhost:3000/api/rag",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "query": "{{question}}"
    },
    "responsePaths": {
      "answer": "answer",
      "sources": "sources[].id"
    }
  },
  "judge": {
    "provider": "claude",
    "model": "claude-sonnet-4-6"
  },
  "scoring": {
    "retrievalK": 5,
    "weights": {
      "retrieval": 0.4,
      "faithfulness": 0.3,
      "correctness": 0.3
    }
  }
}
