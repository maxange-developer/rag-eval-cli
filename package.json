{
  "name": "@massiangelone/rag-eval",
  "version": "0.1.0-alpha.0",
  "description": "Evaluate RAG pipelines: retrieval precision, faithfulness, answer correctness. Multi-provider judge (Claude/OpenAI). Zero-config CLI.",
  "keywords": [
    "rag",
    "llm",
    "eval",
    "evaluation",
    "retrieval",
    "faithfulness",
    "correctness",
    "anthropic",
    "claude",
    "openai",
    "gpt",
    "cli",
    "ci",
    "testing"
  ],
  "license": "MIT",
  "author": "Massimiliano Angelone <massiangelone01@gmail.com>",
  "homepage": "https://github.com/maxange-developer/rag-eval-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxange-developer/rag-eval-cli.git"
  },
  "bugs": {
    "url": "https://github.com/maxange-developer/rag-eval-cli/issues"
  },
  "type": "module",
  "bin": {
    "rag-eval": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "openai": "^6.37.0",
    "ora": "^9.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
